{
  "system_name": "RPG Life Daily Quest System",
  "version": "2.0",
  "design_principles": {
    "daily_quests_per_user": 6,
    "preferred_quests_per_user": 3,
    "random_quests_per_day": 3,
    "philosophy": "consistency_first",
    "visible_difficulty_labels": false,
    "streak_rule": {
      "success_threshold_completed_quests": 4,
      "hold_threshold_completed_quests": 3,
      "reset_threshold_completed_quests_max": 2
    },
    "streak_xp_multiplier": [
      {
        "min_streak": 0,
        "max_streak": 2,
        "multiplier": 1
      },
      {
        "min_streak": 3,
        "max_streak": 6,
        "multiplier": 1.05
      },
      {
        "min_streak": 7,
        "max_streak": 13,
        "multiplier": 1.1
      },
      {
        "min_streak": 14,
        "max_streak": 20,
        "multiplier": 1.15
      },
      {
        "min_streak": 21,
        "max_streak": 29,
        "multiplier": 1.2
      },
      {
        "min_streak": 30,
        "max_streak": 9999,
        "multiplier": 1.3
      }
    ],
    "daily_generation_template": {
      "slots": [
        "BODY",
        "MIND",
        "DISCIPLINE",
        "RECOVERY",
        "SOCIAL",
        "ADAPTIVE"
      ]
    },
    "anti_overload_rules": {
      "max_total_effort_score": 21,
      "max_total_time_estimate_min": 140,
      "max_long_quests_per_day": 2,
      "long_quest_threshold_min": 45,
      "max_high_physical_load_per_day": 2,
      "max_high_mental_load_per_day": 2,
      "max_high_social_pressure_per_day": 1,
      "high_load_threshold": 3,
      "min_quick_win_quests_per_day": 2,
      "quick_win_effort_score_max": 1
    },
    "milestones": [
      {
        "completed_quests": 4,
        "label": "day_secured",
        "bonus_xp": 20
      },
      {
        "completed_quests": 5,
        "label": "strong_day",
        "bonus_xp": 25
      },
      {
        "completed_quests": 6,
        "label": "perfect_day",
        "bonus_xp": 25,
        "bonus_token": 1
      }
    ],
    "rerolls": {
      "free_rerolls_per_day": 1,
      "same_group_forbidden": true,
      "preserve_daily_balance": true
    }
  },
