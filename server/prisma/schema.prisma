generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                 @id @default(cuid())
  username                  String                 @unique
  displayName               String
  photoUrl                  String                 @default("")
  preferredQuestIds         String                 @default("")
  randomQuestIds            String                 @default("")
  previousRandomQuestIds    String                 @default("")
  level                     Int                    @default(1)
  xp                        Int                    @default(0)
  xpNext                    Int                    @default(250)
  streak                    Int                    @default(0)
  tokens                    Int                    @default(0)
  theme                     String                 @default("adventure")
  lastStreakIncreaseAt      DateTime?
  streakFreezeExpiresAt     DateTime?
  lastFreeTaskRerollAt      DateTime?
  lastDailyRerollAt         DateTime?
  extraRerollsToday         Int                    @default(0)
  lastDailyResetAt          DateTime               @default(now())
  lastCitySpinDayKey        String                 @default("")
  districtLevels            String                 @default("0,0,0,0,0")
  lastCitySpinAt            DateTime?
  lastBusinessClaimDayKey   String                 @default("")
  lastSquareBonusDayKey     String                 @default("")
  monthlyFreezeClaims       String                 @default("")
  vacationStartedAt         DateTime?
  vacationEndsAt            DateTime?
  lastVacationAt            DateTime?
  streakFreezeCharges       Int                    @default(0)
  lastFreezePurchaseWeekKey String                 @default("")
  xpBoostExpiresAt          DateTime?
  cityResetsPaid            Int                    @default(0)
  tokensSpentTotal          Int                    @default(0)
  preferredLanguage         String                 @default("")
  cityName                  String                 @default("")
  isDevTester               Boolean                @default(false)
  maxStreak                 Int                    @default(0)
  onboardingSkippedAt       DateTime?
  onboardingTourCompletedAt DateTime?
  handle                    String?                @unique
  streakBurnedAt            DateTime?
  streakBurnedFromValue     Int                    @default(0)
  lastStreakDecayCheckAt    DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  customQuests              CustomQuest[]
  dailyScores               DailyScore[]
  friendshipsB              Friendship[]           @relation("friendB")
  friendshipsA              Friendship[]           @relation("friendA")
  invitesReceived           Invite[]               @relation("invitesReceived")
  invitesSent               Invite[]               @relation("invitesSent")
  friendRequestsSent        FriendRequest[]        @relation("friendRequestsSent")
  friendRequestsReceived    FriendRequest[]        @relation("friendRequestsReceived")
  challengesCreated         GroupChallenge[]       @relation("challengeCreator")
  challengeParticipations   ChallengeParticipant[]
  challengeLogs             ChallengeLogEntry[]
  completions               QuestCompletion[]
  timerSessions             QuestTimerSession[]
  questCounters             QuestCounter[]
  questNotes                QuestNote[]
  achievements              UserAchievement[]
}

model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  code       String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
}

model CustomQuest {
  id              Int      @id @default(autoincrement())
  userId          String
  title           String
  description     String   @default("")
  needsTimer      Boolean  @default(false)
  timeEstimateMin Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyScore {
  id             String   @id @default(cuid())
  userId         String
  dayKey         String
  xpToday        Int      @default(0)
  tasksCompleted Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
  @@index([userId, dayKey])
}

model QuestCompletion {
  id                String   @id @default(cuid())
  userId            String
  questId           Int
  dayKey            String
  completedAt       DateTime @default(now())
  completionPercent Int      @default(100)
  elapsedMs         Int      @default(0)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, dayKey])
  @@index([userId, dayKey])
  @@index([userId, completedAt])
}

model QuestTimerSession {
  id            String    @id @default(cuid())
  userId        String
  questId       Int
  dayKey        String
  startedAt     DateTime
  totalPausedMs Int       @default(0)
  pausedAt      DateTime?
  stoppedAt     DateTime?
  status        String    @default("running")
  elapsedMs     Int?
  percent       Int?
  xpAwarded     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, questId, dayKey])
  @@index([userId, status])
}

model QuestCounter {
  id            String    @id @default(cuid())
  userId        String
  questId       Int
  dayKey        String
  count         Int       @default(0)
  target        Int
  lastTickAt    DateTime?
  windowStartAt DateTime?
  windowTicks   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, dayKey])
  @@index([userId, dayKey])
}

model QuestNote {
  id        String   @id @default(cuid())
  userId    String
  questId   Int
  dayKey    String
  kind      String   @default("note")
  payload   String   @default("")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, kind])
}

model Invite {
  id            String    @id @default(cuid())
  code          String    @unique
  inviterId     String
  invitedUserId String?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  acceptedAt    DateTime?
  invitedUser   User?     @relation("invitesReceived", fields: [invitedUserId], references: [id])
  inviter       User      @relation("invitesSent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([inviterId])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userB     User     @relation("friendB", fields: [userBId], references: [id], onDelete: Cascade)
  userA     User     @relation("friendA", fields: [userAId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model FriendRequest {
  id          String    @id @default(cuid())
  fromUserId  String
  toUserId    String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  fromUser    User      @relation("friendRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User      @relation("friendRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

model GroupChallenge {
  id                 String                 @id @default(cuid())
  creatorId          String
  title              String
  description        String                 @default("")
  questTitle         String
  questDescription   String                 @default("")
  needsTimer         Boolean                @default(false)
  timeEstimateMin    Int                    @default(0)
  durationDays       Int                    @default(7)
  startedAt          DateTime               @default(now())
  endsAt             DateTime
  lastAwardedDayKey  String                 @default("")
  groupDaysCompleted Int                    @default(0)
  completionAwarded  Boolean                @default(false)
  createdAt          DateTime               @default(now())
  creator            User                   @relation("challengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants       ChallengeParticipant[]
  logs               ChallengeLogEntry[]

  @@index([creatorId])
  @@index([endsAt])
}

model ChallengeParticipant {
  id                   String         @id @default(cuid())
  challengeId          String
  userId               String
  joinedAt             DateTime       @default(now())
  // acceptedAt is null for pending invites. A challenge only counts as
  // "activated" when there are at least 2 accepted participants.
  acceptedAt           DateTime?
  leftAt               DateTime?
  completions          Int            @default(0)
  consecutiveDays      Int            @default(0)
  lastCompletionDayKey String         @default("")
  tokensEarned         Int            @default(0)
  challenge            GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

model ChallengeLogEntry {
  id          String         @id @default(cuid())
  challengeId String
  userId      String
  type        String
  createdAt   DateTime       @default(now())
  challenge   GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([challengeId, createdAt])
}

model QuestFeedback {
  id           String   @id @default(cuid())
  userId       String
  questId      String
  questionType String   @default("How useful was this task?")
  rating       Int      @default(0)
  textNotes    String?
  createdAt    DateTime @default(now())

  @@index([userId, questId])
}

model Event {
  id        String   @id @default(cuid())
  type      String
  level     String   @default("info")
  userId    String   @default("")
  username  String   @default("")
  platform  String   @default("")
  message   String   @default("")
  stack     String   @default("")
  url       String   @default("")
  userAgent String   @default("")
  meta      String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@index([level])
  @@index([userId])
}
