{
  "expo": {
    "name": "GoHabit",
    "slug": "life-rpg-mobile",
    "scheme": "liferpgmobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.liferpg.mobile",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Allow GoHabit to connect to your Mac during development.",
        "NSBonjourServices": [
          "_expo._tcp",
          "_expo-dev-client._tcp",
          "_expo-development-client._tcp"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "com.liferpg.mobile"
    },
    "extra": {
      "apiBaseUrl": "https://life-rpg-api-router.evgeny-mahnach.workers.dev",
      "webAppUrl": "https://life-rpg-client.onrender.com"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
